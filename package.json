{
    "name": "voice-of-wisdom-dashboard",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "kill": "npx kill-port 3005",
        "dev:local": "vite --mode development --port 3005",
        "dev:uat":   "vite --mode uat --port 3005",
        "dev:stage": "vite --mode stage --port 3005",
        "dev:main":  "vite --mode main --port 3005",
        "build:uat":   "vite build --mode uat",
        "build:stage": "vite build --mode stage",
        "build:main":  "vite build --mode main",
        "temp": "yalc update @lmb-it/kitsconcerto && yarn && yarn run dev:local",
        "refresh:yalc": "yalc remove @lmb-it/kitsconcerto-web && yalc add @lmb-it/kitsconcerto-web && rm -rf node_modules/.vite && rm -rf node_modules/.cache"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.11.5",
        "@hookform/resolvers": "^3.6.0",
        "@lmb-it/kitsconcerto-web": "latest",
        "@react-hook/resize-observer": "^2.0.2",
        "@reduxjs/toolkit": "^2.11.2",
        "@tailwindcss/vite": "^4.1.18",
        "axios": "^1.13.2",
        "chart.js": "^4.5.1",
        "countries-list": "^3.3.0",
        "file-saver": "^2.0.5",
        "framer-motion": "^12.38.0",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "localforage": "^1.10.0",
        "lodash": "^4.17.21",
        "lucide-react": "^0.563.0",
        "match-sorter": "^8.2.0",
        "moment": "^2.30.1",
        "primeflex": "^4.0.0",
        "primeicons": "^7.0.0",
        "primereact": "^10.9.7",
        "react": "^19.2.0",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "^19.2.0",
        "react-error-boundary": "^4.1.2",
        "react-hook-form": "^7.61.1",
        "react-icons": "^5.6.0",
        "react-native-web": "^0.21.2",
        "react-pro-sidebar": "^1.1.0",
        "react-redux": "^9.2.0",
        "react-responsive": "^10.0.1",
        "react-router-dom": "^7.10.1",
        "react-spinners": "^0.17.0",
        "redux-logger": "^3.0.6",
        "redux-persist": "^6.0.0",
        "redux-saga": "^1.4.2",
        "sort-by": "^1.2.0",
        "styled-components": "^6.1.19",
        "swr": "^2.4.1",
        "usehooks-ts": "^3.1.1",
        "xlsx": "^0.18.5",
        "yup": "^1.7.1",
        "yup-password": "^0.4.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/lodash": "^4.17.23",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@types/redux-logger": "^3.0.13",
        "@vitejs/plugin-react": "^5.1.2",
        "autoprefixer": "^10.4.22",
        "csstype": "^3.2.3",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "postcss": "^8.5.6",
        "sass": "^1.94.2",
        "tailwindcss": "^4.1.17",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.4",
        "vite": "npm:rolldown-vite@7.2.5"
    },
    "overrides": {
        "vite": "npm:rolldown-vite@7.2.5"
    },
    "packageManager": "yarn@1.22.22"
}
